# Docker Compose environment
POSTGRES_PASSWORD=changeme
N8N_USER=admin
N8N_PASSWORD=changeme
WEBHOOK_URL=http://localhost:5678

# Set these in n8n credential store, not here:
# ANTHROPIC_API_KEY=sk-ant-...
# YOUTUBE_API_KEY=AIza...
# PERPLEXITY_API_KEY=pplx-...
# GMAIL credentials: configure via n8n's built-in Gmail OAuth2
# GITHUB_TOKEN: configure via n8n's GitHub credential (PAT with contents:write)

# --- n8n MCP (instance-level, Settings -> MCP -> Connection details) ---
# Used by .mcp.json so Claude Code can call n8n tools directly.
# Export these in the shell BEFORE launching Claude Code; not committed.
# N8N_MCP_URL=https://n8n.srv1565522.hstgr.cloud/mcp/<connection-path-from-UI>
# N8N_MCP_TOKEN=<personal MCP Access Token from the Access Token tab>

# --- n8n REST API (fallback deploy script only) ---
# Used by scripts/deploy_n8n_workflows.sh when MCP is unavailable.
# N8N_BASE_URL=https://n8n.srv1565522.hstgr.cloud
# N8N_API_KEY=<n8n personal API key from Settings -> n8n API>

